<!--
  D-Bus 接口定义文件 — com.example.Vehicle

  使用 gdbus-codegen 根据此文件自动生成:
    - DemoVehicleSkeleton  (服务端骨架 — 继承它实现业务逻辑)
    - DemoVehicleProxy      (客户端代理 — 调用远程方法/监听信号)

  增删改查方法/信号/属性只需修改此文件, 重新 cmake 即可。
-->
<node>
  <interface name="com.example.Vehicle">

    <!--
      GetVehicleInfo — 获取车辆基本信息
      返回: vehicle_id(s), speed(d), odometer(d)
    -->
    <method name="GetVehicleInfo">
      <arg type="s" name="vehicle_id" direction="out"/>
      <arg type="d" name="speed"      direction="out"/>
      <arg type="d" name="odometer"   direction="out"/>
    </method>

    <!--
      SpeedChanged — 速度变化信号
      参数: new_speed(d) 单位 km/h
    -->
    <signal name="SpeedChanged">
      <arg type="d" name="new_speed"/>
    </signal>

    <!--
      Speed — 当前速度属性 (只读, double, 单位 km/h)
    -->
    <property name="Speed" type="d" access="read"/>

  </interface>
</node>
